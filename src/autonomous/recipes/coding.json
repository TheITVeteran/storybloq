{
  "id": "coding",
  "schemaVersion": 2,
  "pipeline": ["PICK_TICKET", "PLAN", "PLAN_REVIEW", "IMPLEMENT", "CODE_REVIEW", "FINALIZE", "COMPLETE"],
  "postComplete": ["ISSUE_SWEEP"],
  "stages": {
    "PLAN_REVIEW": { "backends": ["codex", "agent"] },
    "CODE_REVIEW": { "backends": ["codex", "agent"] },
    "WRITE_TESTS": { "enabled": false, "command": "npm test", "onExhaustion": "plan" },
    "VERIFY": { "enabled": false, "startCommand": "npm run dev", "readinessUrl": "http://localhost:3000", "endpoints": [] },
    "ISSUE_SWEEP": { "enabled": false }
  },
  "dirtyFileHandling": "block",
  "defaults": {
    "maxTicketsPerSession": 3,
    "compactThreshold": "high",
    "reviewBackends": ["codex", "agent"],
    "handoverInterval": 5
  }
}
